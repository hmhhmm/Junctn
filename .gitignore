# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/frontend/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/frontend/.next/
/frontend/out/

# production
/build

# Python bytecode
__pycache__/
*.py[cod]
.pytest_cache/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — never commit credentials
/frontend/.env
/frontend/.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
/frontend/next-env.d.ts

# integration token store (contains OAuth tokens — never commit)
/frontend/data/tokens.json
