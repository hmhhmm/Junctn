# ─── Google OAuth ───────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorised redirect URI: http://localhost:3000/api/auth/google/callback
# 4. Enable Calendar API and Gmail API in the API Library
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# 1. Open Telegram, message @BotFather → /newbot
# 2. Copy the token it gives you below
TELEGRAM_BOT_TOKEN=

# ─── App base URL (change if running on a different port) ────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
